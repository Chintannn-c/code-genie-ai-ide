# Code Genie: Production Environment Template
# Copy this to .env and fill in your keys

# AI API Keys (Required)
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
HUGGINGFACE_API_KEY=your_huggingface_key_here

# Google Auth (Required for Login)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=your_google_web_client_id.apps.googleusercontent.com

# Database (Default works for Docker)
MONGO_URI=mongodb://mongodb:27017
DB_NAME=code_genie_db

# Security (CRITICAL: Change these in production)
JWT_SECRET=generate_a_random_long_string_here
JWT_ALGORITHM=HS256

# Paths (Production paths)
ARTIFACTS_PATH=/data/artifacts
UPLOAD_PATH=/data/uploads

# CORS (Comma separated list of your domains)
ALLOWED_ORIGINS=https://your-app-domain.com,https://your-tunnel-url.ngrok-free.dev
