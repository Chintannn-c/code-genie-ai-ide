# ============================================================
# CODE GENIE PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================

# --- AI PROVIDERS ---
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
GITHUB_API_KEY=your_github_key_here

# --- DISTRIBUTED DATABASE (MONGODB ATLAS) ---
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/ai_code_assistant?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
DB_NAME=ai_code_assistant

# --- DISTRIBUTED CACHE (UPSTASH REDIS) ---
# Format: rediss://default:<password>@<host>:<port>
REDIS_URL=

# --- VECTOR MEMORY ---
# Use 'local' or a ChromaDB Cloud URL
CHROMADB_URL=local

# --- AUTHENTICATION ---
# Generate a secure 64-character hex string for production
JWT_SECRET=genie-dev-secret-key-change-in-production
JWT_ALGORITHM=HS256

# --- FRONTEND (VERCEL) ---
# Used for CORS protection
ALLOWED_ORIGINS=https://code-genie.vercel.app,https://code-genie.up.railway.app
